# ─── BH-Licit Backend ─────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env real no Git!

# Banco de Dados
POSTGRES_USER=admin
POSTGRES_PASSWORD=MUDE_ESTA_SENHA
POSTGRES_DB=licitacoes

# Redis (Fila)
REDIS_HOST=licitacoes_redis
REDIS_PORT=6379

# Inteligência Artificial
GROQ_API_KEY=
GEMINI_API_KEY=

# ANVISA API (Portal de APIs - https://api.anvisa.gov.br)
ANVISA_CLIENT_ID=
ANVISA_CLIENT_SECRET=

# CORS - origens permitidas (separar por vírgula)
CORS_ORIGINS=["http://localhost:3000"]

# Segurança
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION

# Debug (true = logs SQL ativados)
DEBUG=false
